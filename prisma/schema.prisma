generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id               String              @id @default(uuid())
  code             String              @unique
  name             String              @unique
  description      String?
  is_active        Boolean             @default(true)
  employees        Employee[]
  rolesPermissions Roles_Permissions[]
  usersRoles       Users_Roles[]
}

model Permissions {
  id               String              @id @default(uuid())
  code             String              @unique
  name             String
  module           String?
  resource         String?
  action           String?
  resource_name    String?
  rolesPermissions Roles_Permissions[]
}

model Roles_Permissions {
  roleId       String
  permissionId String
  permission   Permissions @relation(fields: [permissionId], references: [id])
  role         Role        @relation(fields: [roleId], references: [id])

  @@id([roleId, permissionId])
}

model Users_Roles {
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@id([userId, roleId])
}

model User {
  id              String                @id @default(uuid())
  username        String                @unique
  password        String
  account_type    String                @default("ADMIN")
  isActive        Boolean               @default(true)
  employeeId      String?               @unique
  customerId      String?               @unique
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  auditLogs       Audit_Logs[]
  contracts       Contracts[]
  cskhNotes       Customer_Care_Notes[]
  importHistories Import_History[]
  customer        Customer?             @relation(fields: [customerId], references: [id])
  employee        Employee?             @relation(fields: [employeeId], references: [id])
  usersRoles      Users_Roles[]
}

model Audit_Logs {
  id        String   @id @default(uuid())
  userId    String
  action    String
  tableName String
  oldData   Json?
  newValue  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Region {
  id              String             @id @default(uuid())
  code            String             @unique
  name            String
  address         String?
  isActive        Boolean            @default(true)
  managerId       String?
  employeeRegions Employee_Regions[]
  manager         Employee?          @relation("RegionManager", fields: [managerId], references: [id])
}

model Employee_Regions {
  employeeId String
  regionCode String
  isMain     Boolean  @default(false)
  employee   Employee @relation(fields: [employeeId], references: [id])
  region     Region   @relation(fields: [regionCode], references: [code])

  @@id([employeeId, regionCode])
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id                           String               @id @default(uuid())
  employeeCode                 String               @unique
  roleCode                     String?
  fullName                     String
  email                        String?
  gender                       String?
  dob                          DateTime?
  address                      String?
  phone                        String?
  joinDate                     DateTime?
  leaveDate                    DateTime?
  isActive                     Boolean              @default(true)
  seniorDeptManagerId          String?
  deptManagerId                String?
  managerId                    String?
  createdAt                    DateTime             @default(now())
  updatedAt                    DateTime             @updatedAt
  contractEmployees            Contract_Employees[]
  contractsAsDeptManager       Contracts[]          @relation("ContractDeptManager")
  contractsAsManager           Contracts[]          @relation("ContractManager")
  contractsAsSeniorDeptManager Contracts[]          @relation("ContractSeniorDeptManager")
  deptManager                  Employee?            @relation("DeptManager", fields: [deptManagerId], references: [id])
  deptSubs                     Employee[]           @relation("DeptManager")
  manager                      Employee?            @relation("DirectManager", fields: [managerId], references: [id])
  directSubs                   Employee[]           @relation("DirectManager")
  role                         Role?                @relation(fields: [roleCode], references: [code])
  seniorDeptManager            Employee?            @relation("SeniorDeptManager", fields: [seniorDeptManagerId], references: [id])
  seniorDeptSubs               Employee[]           @relation("SeniorDeptManager")
  employeeRegions              Employee_Regions[]
  files                        Files[]
  managedRegions               Region[]             @relation("RegionManager")
  user                         User?
}

model Customer {
  id             String      @id @default(uuid())
  fullName       String
  representative String?
  taxCode        String?
  phone          String?     @unique
  email          String?
  dob            DateTime?
  address        String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  contracts      Contracts[]
  user           User?
}

model Contracts {
  id                  String                @id @default(uuid())
  contractCode        String                @unique
  title               String
  type                ContractType
  status              ContractStatus        @default(ACTIVE)
  note                String?
  features            String?
  signDate            DateTime?
  submissionDate      DateTime?
  totalAmount         Decimal?              @db.Decimal(18, 2)
  vatAmount           Decimal?              @db.Decimal(18, 2)
  vatRate             Decimal?              @db.Decimal(5, 2)
  paidAmount          Decimal?              @db.Decimal(18, 2)
  remainingAmount     Decimal?              @db.Decimal(18, 2)
  customerId          String
  regionCode          String?
  managerId           String?
  deptManagerId       String?
  seniorDeptManagerId String?
  createdById         String
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  contractEmployees   Contract_Employees[]
  renewals            Contract_Renewals[]
  creator             User                  @relation(fields: [createdById], references: [id])
  customer            Customer              @relation(fields: [customerId], references: [id])
  deptManager         Employee?             @relation("ContractDeptManager", fields: [deptManagerId], references: [id])
  manager             Employee?             @relation("ContractManager", fields: [managerId], references: [id])
  seniorDeptManager   Employee?             @relation("ContractSeniorDeptManager", fields: [seniorDeptManagerId], references: [id])
  cskhNotes           Customer_Care_Notes[]
  files               Files[]
  receipts            Receipt[]
  services            Service[]
}

model Contract_Employees {
  contractId String
  employeeId String
  isMain     Boolean   @default(true)
  contract   Contracts @relation(fields: [contractId], references: [id])
  employee   Employee  @relation(fields: [employeeId], references: [id])

  @@id([contractId, employeeId])
}

model Contract_Renewals {
  id          String    @id @default(uuid())
  contractId  String
  renewalDate DateTime
  note        String?
  processedBy String?
  createdAt   DateTime  @default(now())
  contract    Contracts @relation(fields: [contractId], references: [id])
}

model Customer_Care_Notes {
  id          String    @id @default(uuid())
  contractId  String
  createdById String
  content     String
  createdAt   DateTime  @default(now())
  contract    Contracts @relation(fields: [contractId], references: [id])
  creator     User      @relation(fields: [createdById], references: [id])
}

model Service {
  id          String      @id @default(uuid())
  contractId  String
  type        ServiceType
  name        String?
  order       Int?
  price       Decimal?    @db.Decimal(18, 2)
  vatRate     Decimal?    @db.Decimal(5, 2)
  vatAmount   Decimal?    @db.Decimal(18, 2)
  total       Decimal?    @db.Decimal(18, 2)
  createdAt   DateTime    @default(now())
  domainInfo  Domain?
  hostingInfo Hosting?
  receipts    Receipt[]
  contract    Contracts   @relation(fields: [contractId], references: [id])
}

model Domain {
  id         String    @id @default(uuid())
  serviceId  String    @unique
  domainName String
  provider   String?
  expiryDate DateTime?
  service    Service   @relation(fields: [serviceId], references: [id])
}

model Hosting {
  id        String  @id @default(uuid())
  serviceId String  @unique
  duration  String?
  storage   String?
  service   Service @relation(fields: [serviceId], references: [id])
}

model Receipt {
  id            String    @id @default(uuid())
  contractId    String
  name          String
  receiptCode   String?
  paymentMethod String?
  order         Int?
  amount        Decimal?  @db.Decimal(18, 2)
  paidDate      DateTime?
  createdAt     DateTime  @default(now())
  serviceId     String?
  contract      Contracts @relation(fields: [contractId], references: [id])
  service       Service?  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Files {
  id         String     @id @default(uuid())
  fileName   String
  filePath   String
  publicId   String
  fileType   String
  category   String
  employeeId String?
  contractId String?
  createdAt  DateTime   @default(now())
  contract   Contracts? @relation(fields: [contractId], references: [id])
  employee   Employee?  @relation(fields: [employeeId], references: [id])
}

model Import_History {
  id          String   @id @default(uuid())
  fileName    String
  uploadById  String
  module      String
  totalRows   Int      @default(0)
  successRows Int      @default(0)
  failedRows  Int      @default(0)
  status      String
  errorLog    Json?
  createdAt   DateTime @default(now())
  uploader    User     @relation(fields: [uploadById], references: [id])
}

model System_Settings {
  id          String  @id @default(uuid())
  key         String  @unique
  value       String
  description String?
}

enum ContractType {
  WEB
  HOSTING
  DOMAIN
  ADS
}

enum ContractStatus {
  ACTIVE
  PENDING
  COMPLETED
  CANCELLED
}

enum ServiceType {
  WEB
  HOSTING
  DOMAIN
  ADS_FB
  ADS_GG
  OTHER
}
